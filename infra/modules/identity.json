{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.43.8.12551",
      "templateHash": "3752590230702755128"
    }
  },
  "parameters": {
    "namePrefix": {
      "type": "string",
      "minLength": 2
    },
    "location": {
      "type": "string"
    },
    "githubOrg": {
      "type": "string"
    },
    "githubRepo": {
      "type": "string"
    }
  },
  "resources": [
    {
      "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
      "apiVersion": "2023-01-31",
      "name": "[format('{0}-api-id', parameters('namePrefix'))]",
      "location": "[parameters('location')]"
    },
    {
      "type": "Microsoft.ManagedIdentity/userAssignedIdentities/federatedIdentityCredentials",
      "apiVersion": "2023-01-31",
      "name": "[format('{0}/{1}', format('{0}-api-id', parameters('namePrefix')), 'github-actions-master')]",
      "properties": {
        "issuer": "https://token.actions.githubusercontent.com",
        "subject": "[format('repo:{0}/{1}:ref:refs/heads/master', parameters('githubOrg'), parameters('githubRepo'))]",
        "audiences": [
          "api://AzureADTokenExchange"
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-api-id', parameters('namePrefix')))]"
      ]
    }
  ],
  "outputs": {
    "identityId": {
      "type": "string",
      "value": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-api-id', parameters('namePrefix')))]"
    },
    "identityClientId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-api-id', parameters('namePrefix'))), '2023-01-31').clientId]"
    },
    "identityPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-api-id', parameters('namePrefix'))), '2023-01-31').principalId]"
    }
  }
}