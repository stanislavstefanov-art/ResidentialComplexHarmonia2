{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.43.8.12551",
      "templateHash": "9908446516506647733"
    }
  },
  "parameters": {
    "namePrefix": {
      "type": "string",
      "minLength": 2
    },
    "location": {
      "type": "string"
    },
    "sqlAdminPassword": {
      "type": "securestring"
    }
  },
  "resources": [
    {
      "type": "Microsoft.Sql/servers",
      "apiVersion": "2022-05-01-preview",
      "name": "[format('{0}-sql', parameters('namePrefix'))]",
      "location": "[parameters('location')]",
      "properties": {
        "administratorLogin": "harmonia-admin",
        "administratorLoginPassword": "[parameters('sqlAdminPassword')]",
        "version": "12.0"
      }
    },
    {
      "type": "Microsoft.Sql/servers/databases",
      "apiVersion": "2022-05-01-preview",
      "name": "[format('{0}/{1}', format('{0}-sql', parameters('namePrefix')), format('{0}-db', parameters('namePrefix')))]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "GP_S_Gen5",
        "tier": "GeneralPurpose",
        "family": "Gen5",
        "capacity": 1
      },
      "properties": {
        "autoPauseDelay": 60,
        "minCapacity": "[json('0.5')]",
        "requestedBackupStorageRedundancy": "Local"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Sql/servers', format('{0}-sql', parameters('namePrefix')))]"
      ]
    },
    {
      "type": "Microsoft.Sql/servers/firewallRules",
      "apiVersion": "2022-05-01-preview",
      "name": "[format('{0}/{1}', format('{0}-sql', parameters('namePrefix')), 'AllowAzureServices')]",
      "properties": {
        "startIpAddress": "0.0.0.0",
        "endIpAddress": "0.0.0.0"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Sql/servers', format('{0}-sql', parameters('namePrefix')))]"
      ]
    }
  ],
  "outputs": {
    "serverFqdn": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Sql/servers', format('{0}-sql', parameters('namePrefix'))), '2022-05-01-preview').fullyQualifiedDomainName]"
    },
    "databaseName": {
      "type": "string",
      "value": "[format('{0}-db', parameters('namePrefix'))]"
    }
  }
}